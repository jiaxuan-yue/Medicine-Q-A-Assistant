# ============================================================
# 中医药智能知识服务平台 — 环境变量模板
# 复制为 .env 并填入实际值
# ============================================================

# ── 应用 ────────────────────────────────────────────────
APP_NAME=TCM-RAG-Platform
DEBUG=false
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./data/tcm_rag.db
ENABLE_DEMO_DATA=true

# ── MySQL ───────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=tcm_root_123
MYSQL_DATABASE=tcm_rag

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Elasticsearch ───────────────────────────────────────
ES_HOSTS=["http://localhost:9200"]
ES_INDEX_PREFIX=tcm

# ── Neo4j ───────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tcm_neo4j_123

# ── MinIO ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=tcm-documents

# ── DashScope LLM ──────────────────────────────────────
DASHSCOPE_API_KEY=sk-966c7600840f4a66b2329657de33c065
LLM_MODEL=qwen-max
LLM_REWRITE_MODEL=qwen-plus
LLM_TIMEOUT=15
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
RERANKER_MODEL=gte-rerank

# ── 检索参数 ────────────────────────────────────────────
SPARSE_TOP_K=20
DENSE_TOP_K=20
GRAPH_TOP_K=15
FUSION_TOP_K=20
RERANK_K=5
RRF_K=60
GRAPH_MAX_HOPS=2
RETRIEVAL_TIMEOUT=1.0

# ── 特性开关 ────────────────────────────────────────────
QUERY_REWRITE_ENABLED=true
GRAPH_RECALL_ENABLED=true
RERANKER_ENABLED=true

# ── JWT 安全 ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 多轮对话 ────────────────────────────────────────────
HISTORY_WINDOW_SIZE=5
HISTORY_SUMMARY_INTERVAL=5

# ── 限流 ────────────────────────────────────────────────
RATE_LIMIT_USER=60
RATE_LIMIT_QA=10
RATE_LIMIT_ADMIN=120
