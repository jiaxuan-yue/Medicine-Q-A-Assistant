# ============================================================
# 中医药智能知识服务平台 — 环境变量模板
# 复制为 .env 并填入实际值
# ============================================================

# ── 应用 ────────────────────────────────────────────────
APP_NAME=TCM-RAG-Platform
DEBUG=false
API_V1_PREFIX=/api/v1
# 注意：如果配置了 DATABASE_URL，会优先使用它。
# 本地调试可直接使用 SQLite；若改用 docker-compose 中的 MySQL，
# 请改成 mysql+asyncmy://root:your_mysql_password@127.0.0.1:3307/tcm_db
DATABASE_URL=sqlite+aiosqlite:///./data/tcm_rag.db
ENABLE_DEMO_DATA=true

# ── MySQL ───────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=tcm_db

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Elasticsearch ───────────────────────────────────────
ES_HOSTS=["http://localhost:9200"]
ES_INDEX_PREFIX=tcm

# ── Neo4j ───────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── MinIO ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=tcm-documents

# ── DashScope LLM ──────────────────────────────────────
DASHSCOPE_API_KEY=your_dashscope_api_key
LLM_MODEL=qwen-max
LLM_REWRITE_MODEL=qwen-plus
LLM_TIMEOUT=15
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
RERANKER_MODEL=gte-rerank

# ── 检索参数 ────────────────────────────────────────────
SPARSE_TOP_K=20
DENSE_TOP_K=20
GRAPH_TOP_K=15
FUSION_TOP_K=20
RERANK_K=5
RRF_K=60
GRAPH_MAX_HOPS=2
RETRIEVAL_TIMEOUT=1.0

# ── 特性开关 ────────────────────────────────────────────
QUERY_REWRITE_ENABLED=true
GRAPH_RECALL_ENABLED=false
RERANKER_ENABLED=true
LIVE_CONTEXT_ENABLED=true
LIVE_CONTEXT_TIMEOUT_SECONDS=5.0
LIVE_CONTEXT_TTL_SECONDS=600
MCP_ENVIRONMENT_ENABLED=true

# ── 环境感知 / MCP ──────────────────────────────────────
IP_GEO_API_URL=http://ip-api.com/json/?lang=zh-CN
WEATHER_PROVIDER=auto
QWEATHER_API_HOST=https://devapi.qweather.com
QWEATHER_API_TOKEN=
QWEATHER_API_KEY=
AMAP_API_HOST=https://restapi.amap.com
AMAP_API_KEY=
OPEN_METEO_API_HOST=https://api.open-meteo.com
OPEN_METEO_GEOCODING_API_HOST=https://geocoding-api.open-meteo.com

# ── JWT 安全 ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 多轮对话 ────────────────────────────────────────────
HISTORY_WINDOW_SIZE=5
HISTORY_SUMMARY_INTERVAL=5

# ── 限流 ────────────────────────────────────────────────
RATE_LIMIT_USER=60
RATE_LIMIT_QA=10
RATE_LIMIT_ADMIN=120
